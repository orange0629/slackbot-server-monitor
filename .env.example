# Copy to `.env` and fill in real values. `.env` is gitignored; this template is committed.
# Lines starting with `#` are comments. Quotes around values are optional and stripped.

# --- Slack (required) ---
# Bot user OAuth token, starts with xoxb-
SLACK_TOKEN=
# App-level token for Socket Mode, starts with xapp-
SLACK_APP_TOKEN=

# --- Giphy (optional) ---
# If unset, the giphy_refresh scheduled task no-ops.
GIPHY_API_KEY=

# --- HuggingFace (optional) ---
# Only needed if you switch GIF_REPLY_SIGLIP_MODEL to a gated checkpoint.
HF_TOKEN=
